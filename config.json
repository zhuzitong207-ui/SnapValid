{
    "软件名称": "SnapValid",
    "版本号": "v1.0.0",
    "核心功能": ["键鼠录制回放", "OCR验证码识别", "截图相似度校验"],
    "相似度阈值(0-1)": 0.9,
    "回放循环次数": 1,
    "录制时截图保存路径": "./screenshots/record/",
    "回放对比截图保存路径": "./screenshots/play/",
    "验证码原始图片保存路径": "./screenshots/ocr/",
    "验证码识别结果保存文件": "./ocr_result.txt",
    "录制脚本存储路径": "./scripts/",
    "操作日志文件": "./operation_log.txt",
    "对比结果日志文件": "./compare_result.txt"
}
